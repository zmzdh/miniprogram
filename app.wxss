/** 全局样式 **/

page {
  background: #f6f7fb;
  font-size: 28rpx;
  color: #333;
}

/* ─── 通用卡片 ─── */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

/* ─── 标题 ─── */
.card-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #222;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  color: #333;
}

/* ─── 按钮行 ─── */
.btn-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.btn-row-space {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

/* ─── 表单 ─── */
.form-row {
  margin-bottom: 18rpx;
}

.form-label {
  display: block;
  margin-bottom: 8rpx;
  color: #555;
  font-size: 26rpx;
}

.form-input,
.form-picker {
  height: 76rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 20rpx;
  background: #fafafa;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #007AFF;
  background: #fff;
}

/* ─── 状态标签 ─── */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-success { background: #e8f5e9; color: #2e7d32; }
.tag-warning { background: #fff3e0; color: #ef6c00; }
.tag-error   { background: #ffebee; color: #c62828; }
.tag-info    { background: #e3f2fd; color: #1565c0; }
.tag-gray    { background: #f5f5f5; color: #666; }

/* ─── 空状态 ─── */
.empty-tip {
  color: #999;
  font-size: 26rpx;
  text-align: center;
  padding: 40rpx 0;
}

/* ─── HEX文本 ─── */
.hex-text {
  font-family: 'Courier New', Consolas, monospace;
  word-break: break-all;
  color: #333;
  line-height: 1.7;
  font-size: 26rpx;
}

/* ─── 滚动容器 ─── */
.scroll-y {
  max-height: 500rpx;
}

/* ─── 分隔线 ─── */
.divider {
  height: 1rpx;
  background: #eee;
  margin: 16rpx 0;
}

/* ─── Flex 工具 ─── */
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-start {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* ─── 导航栏页签按钮 ─── */
.nav-tabs {
  display: flex;
  background: #f0f0f0;
  border-radius: 12rpx;
  padding: 4rpx;
  margin-bottom: 20rpx;
}

.nav-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.nav-tab-active {
  background: #007AFF;
  color: #fff;
  font-weight: 600;
}
