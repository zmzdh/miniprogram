<view class="page">
  <!-- 连接状态卡片 -->
  <view class="card">
    <view class="card-title">LIN 设备通讯助手</view>

    <view wx:if="{{isConnected}}" class="status-card status-connected">
      <view class="status-main">
        <view class="status-dot"></view>
        <view class="status-info">
          <view class="status-name">{{connectedDeviceName}}</view>
          <view class="status-id">{{connectedDeviceId}}</view>
          <view wx:if="{{rssi !== null}}" class="status-rssi">信号: {{rssi}} dBm</view>
        </view>
      </view>
      <button type="warn" size="mini" bindtap="handleDisconnect">断开</button>
    </view>

    <view wx:else class="status-card">
      <view class="status-text">{{statusText}}</view>
      <view wx:if="{{rssi !== null}}" class="status-rssi">信号: {{rssi}} dBm</view>
    </view>

    <!-- 未连接时操作 -->
    <view wx:if="{{!isConnected}}" class="btn-row">
      <button type="primary" size="mini" bindtap="handleScan">
        {{isScanning ? '扫描中...' : '扫描设备'}}
      </button>
      <button size="mini" bindtap="handleAutoConnect">自动连接</button>
    </view>

    <!-- 已连接快捷入口 -->
    <view wx:if="{{isConnected}}" class="btn-row">
      <button type="primary" size="mini" bindtap="goTerminal">进入终端</button>
    </view>
  </view>

  <!-- 模式选择 -->
  <view class="card">
    <view class="section-title">工作模式</view>
    <picker mode="selector" range="{{modeOptions}}" range-key="label" value="{{modeIndex}}" bindchange="handleModeChange">
      <view class="form-picker">{{modeOptions[modeIndex].label}}</view>
    </picker>
    <view class="mode-desc">
      <block wx:if="{{modeIndex === 0}}">监听LIN总线数据，不参与通信</block>
      <block wx:elif="{{modeIndex === 1}}">作为主节点，发送帧头并控制总线时序</block>
      <block wx:elif="{{modeIndex === 2}}">作为从节点，响应主节点请求(16通道)</block>
      <block wx:elif="{{modeIndex === 3}}">嗅探模式，捕获总线所有数据</block>
    </view>
  </view>

  <!-- 设备列表 -->
  <view wx:if="{{!isConnected && showDeviceList}}" class="card">
    <view class="section-title">发现的设备 ({{devices.length}})</view>

    <block wx:for="{{devices}}" wx:key="deviceId">
      <view class="device-item">
        <view class="device-main">
          <view class="device-name">{{item.name}}</view>
          <view class="device-id">{{item.deviceId}}</view>
          <view class="device-rssi">
            RSSI: {{item.RSSI}}
            <view class="rssi-bar">
              <view class="rssi-fill" style="width: {{(item.RSSI + 100) * 1.5}}%;"></view>
            </view>
          </view>
        </view>
        <button type="primary" size="mini"
          data-deviceid="{{item.deviceId}}"
          data-devicename="{{item.name}}"
          bindtap="handleConnect">连接</button>
      </view>
    </block>

    <view wx:if="{{devices.length === 0 && isScanning}}" class="empty-tip">
      正在扫描蓝牙设备...
    </view>
    <view wx:if="{{devices.length === 0 && !isScanning}}" class="empty-tip">
      点击「扫描设备」发现附近的蓝牙设备
    </view>
  </view>

  <!-- 快捷信息 -->
  <view class="card">
    <view class="section-title">设备信息</view>
    <view class="info-row">
      <text class="info-label">蓝牙状态</text>
      <text class="info-value">{{isConnected ? '已连接' : '未连接'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">工作模式</text>
      <text class="info-value">{{modeOptions[modeIndex].label}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">默认波特率</text>
      <text class="info-value">19200 bps</text>
    </view>
    <view wx:if="{{rssi !== null}}" class="info-row">
      <text class="info-label">信号强度</text>
      <text class="info-value">{{rssi}} dBm</text>
    </view>
  </view>
</view>
