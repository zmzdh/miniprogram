.page { padding: 24rpx; }

.filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.filter-row:last-child { margin-bottom: 0; }

.filter-label {
  font-size: 26rpx;
  color: #666;
  width: 100rpx;
  flex-shrink: 0;
}

.filter-tags {
  display: flex;
  gap: 8rpx;
}

.filter-tag {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #f0f0f0;
  color: #666;
}

.filter-tag.active {
  background: #007AFF;
  color: #fff;
}

.filter-input {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  max-width: 120rpx;
}

.frame-card:active { background: #f5f5f5; }

.frame-time { font-size: 24rpx; color: #888; }

.frame-id { font-size: 26rpx; font-weight: 600; color: #333; }

.frame-data { margin-top: 8rpx; font-size: 24rpx; }

.frame-crc { font-size: 22rpx; margin-top: 4rpx; }

.crc-ok { color: #4caf50; }
.crc-fail { color: #f44336; }

.log-item {
  padding: 10rpx 0;
  border-bottom: 1rpx dashed #eee;
  font-size: 24rpx;
  line-height: 1.5;
}

.log-item:last-child { border-bottom: none; }

.log-time { color: #888; margin-right: 8rpx; }

.log-msg { color: #333; word-break: break-all; }

.nav-tabs {
  display: flex;
  background: #f0f0f0;
  border-radius: 12rpx;
  padding: 4rpx;
  margin-bottom: 20rpx;
}

.nav-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 10rpx;
}

.nav-tab-active { background: #007AFF; color: #fff; font-weight: 600; }
