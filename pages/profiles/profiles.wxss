.page { padding: 24rpx; }

.profile-card { transition: all 0.2s; }

.profile-active {
  border: 2rpx solid #007AFF;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 700;
}

.profile-desc {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

.profile-meta {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
}

.btn-col {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.profile-detail {
  margin-top: 16rpx;
}

.group-box {
  margin-top: 14rpx;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.group-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #444;
}

.cmd-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
}

.cmd-item:last-child { border-bottom: none; }

.cmd-info { flex: 1; }

.cmd-name {
  font-size: 28rpx;
  font-weight: 600;
}

.cmd-meta {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-card {
  width: 85%;
  max-height: 80vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
}
